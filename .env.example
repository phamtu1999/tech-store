# ==============================
# DATABASE CONFIGURATION
# ==============================
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=localhost
POSTGRES_DB=techstore
POSTGRES_PORT=5432
POSTGRES_SSL_MODE=prefer

# ==============================
# REDIS CONFIGURATION
# ==============================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==============================
# BACKEND CONFIGURATION
# ==============================
BACKEND_PORT=8080
BACKEND_URL=http://localhost:8080
SPRING_PROFILES_ACTIVE=prod

# JWT Secret Key (MUST be changed for production: use a random string > 256 bits)
JWT_SECRET_KEY=YOUR_LONG_RANDOM_SECRET_KEY_HERE

# VNPay Configuration (Get from VNPay Sandbox/Production dashboard)
VNPAY_TMN_CODE=YOUR_VNPAY_TMN_CODE
VNPAY_HASH_SECRET=YOUR_VNPAY_HASH_SECRET

# ==============================
# FRONTEND CONFIGURATION
# ==============================
FRONTEND_PORT=3000
FRONTEND_URL=http://localhost:3000

# ==============================
# APP STORAGE CONFIGURATION
# ==============================
APP_STORAGE_ROOT=/app/data
APP_BACKUP_DIR=/app/data/backups
APP_LOG_DIR=/app/data/logs
APP_BACKUP_SCHEDULE_ENABLED=true
APP_BACKUP_RETENTION_COUNT=10

# ==============================
# CLOUDINARY CONFIGURATION
# ==============================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ==============================
# MAIL CONFIGURATION (GMAIL)
# ==============================
# Email dùng để gửi thông báo (ví dụ: techstore@gmail.com)
SPRING_MAIL_USERNAME=your_gmail_here
# Mật khẩu ứng dụng (App Password) - KHÔNG PHẢI mật khẩu đăng nhập Gmail
SPRING_MAIL_PASSWORD=your_app_password_here
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587

# ==============================
# GOOGLE OAUTH2 CONFIGURATION
# ==============================
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
